{
  "appId": "com.taxcompliance.management",
  "productName": "Tax Compliance Management System",
  "copyright": "Copyright © 2025 Tax Compliance Management System",
  "directories": {
    "output": "release",
    "buildResources": "build-resources"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "extraResources": [
    {
      "from": "../backend",
      "to": "backend",
      "filter": [
        "**/*",
        "!**/venv/**",
        "!**/__pycache__/**",
        "!**/*.pyc",
        "!**/.pytest_cache/**",
        "!**/tests/**"
      ]
    },
    {
      "from": "../storage",
      "to": "storage",
      "filter": ["**/*"]
    },
    {
      "from": "../backups",
      "to": "backups",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.ico",
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Tax Compliance Management System",
    "uninstallDisplayName": "Tax Compliance Management System",
    "license": "build-resources/license.txt",
    "installerIcon": "public/icon.ico",
    "uninstallerIcon": "public/icon.ico",
    "installerHeaderIcon": "public/icon.ico",
    "include": "build-resources/installer.nsh"
  },
  "portable": {
    "artifactName": "${productName}-${version}-portable.${ext}"
  },
  "publish": null,
  "buildDependencies": {
    "beforeBuild": "npm run build",
    "beforePackage": "npm run build"
  },
  "compression": "maximum",
  "removePackageScripts": true,
  "removePackageKeywords": true,
  "removePackageDependencies": ["devDependencies"]
}