{
  "name": "sales-tax-processor",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "node start-dev.js",
    "dev:frontend": "npm run dev --workspace=frontend -- --host 0.0.0.0 --port 3000",
    "dev:backend": "cd backend && source ../backend_env/bin/activate && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend -- --host 0.0.0.0 --port 3000"
  }
}
